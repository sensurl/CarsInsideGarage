@{
    ViewData["Title"] = "The Ultimate Parking Assistant";
}

<div class="container mt-4">

    <div class="text-center mb-4">
        <h1 class="display-5">Find a parking spot in Sofia city</h1>
        <p class="lead">Check availability and fees instantly.</p>
    </div>

    <div class="row justify-content-center text-center">

        <!-- Option 1: Use current location -->
        <div class="col-md-5 mb-4">
                <div class="card shadow-sm p-3 bg-surface border-0">
                <h4 class="text-accent">Use My Location</h4>
                <p class="text-muted small">See available parking spots around where you are right now.</p>
                <button id="btnUseLocation" class="btn btn-primary btn-lg w-100" onclick="findNearest()">
                    Share My Location
                </button>
            </div>
        </div>

        <!-- Option 2: Search another area -->
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm p-3 bg-surface border-0">
                <h4 class="text-accent">Search Another Area</h4>
                <p class="text-muted small">Planning to drive somewhere? Check parking before you go.</p>
        
                <div class="position-relative">
                    <input id="searchBox" class="form-control form-control-lg mb-3"
                           placeholder="Enter address or area…" />
                    <div id="searchSpinner" class="spinner-border spinner-border-sm text-accent position-absolute"
                         style="right: 15px; top: 15px; display: none;" role="status"></div>
                </div>

                <button id="btnSearchArea" class="btn btn-primary w-100 py-2">
                    <i class="bi bi-search me-2"></i>Show on Map
                </button>
        
                <div id="searchError" class="text-error small mt-2" style="display:none;"></div>
            </div>
        </div>

    </div>


    <!-- Inside the mt-5 div in Index.cshtml -->
        <div class="mt-5">
            <div class="d-flex justify-content-between align-items-end mb-2">
            <h4 class="text-white">Or select a spot on the map:</h4>
                <button id="btnUseSelected" class="btn btn-outline-info btn-sm">
                <i class="bi bi-geo-fill me-1"></i> Use Selected Location
                </button>
            </div>
    
        <!-- Added 'position-relative' and checked styles -->
        <div id="map" class="shadow rounded" style="height: 450px; width: 90%; border: 2px solid #333;"></div>
        </div>

</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <!-- global JS -->
    <script src="~/js/site.js"></script>
    
}