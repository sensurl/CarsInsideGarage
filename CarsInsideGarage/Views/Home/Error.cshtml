@model ErrorViewModel
@{
    ViewData["Title"] = "System Error";
}

<div class="card border-0 shadow-lg mt-5" style="border: 1px solid var(--warning-pink) !important;">
    <div class="card-body p-5 text-center">
        <i class="bi bi-exclamation-triangle-fill display-3" style="color: var(--warning-pink);"></i>
        <h1 class="mt-3" style="color: var(--text-main);">Something went wrong</h1>
        <p class="text-muted">Our system encountered an unexpected error while processing your request.</p>

        <div class="alert alert-warning mt-4 text-start">
            <h4 class="alert-heading"><i class="bi bi-info-circle"></i> Technical Details</h4>
            <p class="mb-0 small font-monospace">Request ID: <code>@Model.RequestId</code></p>
        </div>

        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-4">
            Return to Dashboard
        </a>
    </div>
</div>