@{
    ViewData["Title"] = "Page Not Found";
}

<div class="d-flex flex-column align-items-center justify-content-center text-center mt-5">
    <h1 class="display-1 fw-bold" style="color: var(--accent);">404</h1>
    <h2 class="mb-4">Oops! The parking spot you're looking for doesn't exist.</h2>
    <p class="text-muted mb-5">The page might have been moved, deleted, or you might have typed the URL incorrectly.</p>

    <div class="d-flex gap-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4 py-2">
            <i class="bi bi-house-door"></i> Back to Home
        </a>
        <a href="javascript:history.back()" class="btn btn-info px-4 py-2">
            <i class="bi bi-arrow-left"></i> Go Back
        </a>
    </div>
</div>