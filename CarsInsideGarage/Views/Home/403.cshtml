@{
    ViewData["Title"] = "Access Denied";
}

<div class="d-flex flex-column align-items-center justify-content-center text-center mt-5">
    <div class="mb-4">
        <i class="bi bi-shield-lock-fill" style="font-size: 6rem; color: var(--delete-magenta);"></i>
    </div>
    <h1 class="display-4 fw-bold" style="color: var(--text-main);">Area Restricted</h1>
    <h3 class="text-muted mb-4">You do not have the required permissions to view this parking sector.</h3>

    <div class="p-4 rounded-3 mb-5" style="background-color: var(--bg-surface); border: 1px solid var(--border); max-width: 500px;">
        <p class="mb-0">If you believe you should have access, please contact the system supervisor.</p>
    </div>

    <div class="d-flex gap-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
            Return to Dashboard
        </a>
        <form asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="btn btn-info">
                Switch Account
            </button>
        </form>
    </div>
</div>