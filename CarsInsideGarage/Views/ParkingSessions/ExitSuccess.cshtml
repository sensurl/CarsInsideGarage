@model int

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 bg-surface text-center p-5" style="border: 1px solid var(--border) !important;">
                <div class="mb-4">
                    <div class="position-relative d-inline-block">
                        <i class="bi bi-p-circle-fill display-1 text-muted opacity-25"></i>
                        <i class="bi bi-box-arrow-right text-accent position-absolute"
                           style="bottom: 10px; right: -10px; font-size: 3rem;"></i>
                    </div>
                </div>
                
                <h2 class="text-white fw-bold mb-3">Exit Completed</h2>
                
                <p class="text-muted fs-5 mb-4">
                    The gate is open! You have successfully closed session
                    <span class="text-accent fw-bold">#@Model</span>. Safe travels!
                </p>

                <div class="d-grid gap-2">
                    <a asp-action="MySessions" class="btn btn-register py-3">
                        <i class="bi bi-house-door me-2"></i> Return to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>