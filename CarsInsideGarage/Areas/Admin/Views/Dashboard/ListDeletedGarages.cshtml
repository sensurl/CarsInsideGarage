@model IEnumerable<CarsInsideGarage.Data.Entities.Garage>

@{
    ViewData["Title"] = "Deleted Garages";
}

<h2 class="mb-4">Deleted Garages</h2>

<table class="table table-dark table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Owner</th>
            <th>Deleted At</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var garage in Model)
        {
            <tr>
                <td>@garage.Name</td>
                <td>@garage.UserId</td>
                <td>@garage.DeletedAt?.ToString("g")</td>
                <td>
                    <form asp-area="Admin"
                          asp-controller="Dashboard"
                          asp-action="RestoreGarage"
                          method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="garageId" value="@garage.Id" />

                        <button class="btn btn-success btn-sm">
                            <i class="bi bi-arrow-counterclockwise"></i> Restore
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary mt-3">
    Back to Dashboard
</a>
