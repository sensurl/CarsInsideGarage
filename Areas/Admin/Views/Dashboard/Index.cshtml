@model CarsInsideGarage.Areas.Admin.Models.DashboardViewModel

@{
    ViewData["Title"] = "Admin Overview";
}

<div class="mb-4">
    <h1 class="display-5 fw-bold" style="color: var(--accent);">Admin Dashboard</h1>
    <p class="text-muted">Real-time system monitoring</p>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-building-fill-check display-6 mb-2" style="color: var(--accent);"></i>
                <h6 class="text-muted text-uppercase small fw-bold">Total Garages</h6>
                <h2 class="display-6 fw-bold">@Model.TotalGarages</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-p-circle-fill display-6 mb-2 text-info"></i>
                <h6 class="text-muted text-uppercase small fw-bold">Available Spots</h6>
                <h2 class="display-6 fw-bold">@Model.TotalFreeSpotsAvailable</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-clock-history display-6 mb-2" style="color: var(--warning-pink);"></i>
                <h6 class="text-muted text-uppercase small fw-bold">Active Sessions</h6>
                <h2 class="display-6 fw-bold">@Model.TotalActiveSessions</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 shadow-sm border-warning">
            <div class="card-body text-center">
                <i class="bi bi-trash-fill display-6 mb-2 text-warning"></i>
                <h6 class="text-muted text-uppercase small fw-bold">Deleted Garages</h6>
                <h2 class="display-6 fw-bold">@Model.DeletedGaragesCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card h-100 shadow-sm border-warning">
            <div class="card-body text-center">
                <i class="bi bi-person-x-fill display-6 mb-2 text-warning"></i>
                <h6 class="text-muted text-uppercase small fw-bold">Deleted Users</h6>
                <h2 class="display-6 fw-bold">@Model.DeletedUsersCount</h2>
            </div>
        </div>
    </div>

</div>

<div class="card border-0">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-bold">Management Actions</span>
    </div>
    <div class="card-body d-flex gap-3 flex-wrap">
        
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="ListDeletedUsers" class="btn btn-primary">
            <i class="bi bi-people"></i> Restore Users
        </a>

        <a asp-area="Admin" asp-controller="Dashboard" asp-action="ListDeletedGarages" class="btn btn-warning">
            <i class="bi bi-trash"></i> Restore Garages
        </a>

    </div>
</div>