@using System.Globalization

@model CarsInsideGarage.Models.ViewModels.GarageDetailsViewModel

@{
    ViewData["Title"] = "Garage Details";
}

<div class="container mt-4">
    <h1 class="text-white mb-4">Garage Details</h1>

    <div class="card shadow">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="mb-0">@Model.Name</h2>
            <span class="badge fs-5" style="background-color: var(--bg-main); color: @(Model.FreeSpots > 0 ? "var(--accent)" : "var(--warning-pink)"); border: 1px solid var(--border);">
                @Model.FreeSpots Spots Left
            </span>
        </div>

        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="text-muted small text-uppercase fw-bold d-block">Area</label>
                        <span class="fs-5 text-white">@Model.Area</span>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted small text-uppercase fw-bold d-block">GPS Coordinates</label>
                        <code class="text-info fs-6">@Model.ParkingCoordinates</code>
                    </div>
                </div>

                <div class="col-md-6 text-end">
                    @{
                        var coords = Model.ParkingCoordinates?.Split(',');
                        var lat = coords?.Length > 0 ? coords[0].Trim() : "0";
                        var lng = coords?.Length > 1 ? coords[1].Trim() : "0";
                    }
                    <div id="map"
                         style="height: 250px; width: 100%;"
                         class="rounded shadow-sm"
                         data-mode="preview"
                         data-lat="@lat"
                         data-lng="@lng"
                         data-name="@Model.Name">
                    </div>

                    @if (!User.Identity.IsAuthenticated)
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg">
                            Log in to Park
                        </a>
                    }
                    else if (User.IsInRole("Driver"))
                        {
                        if (Model.FreeSpots > 0)
                            {
                                <form asp-controller="ParkingSessions" asp-action="Start" method="post" class="d-inline">
                               
                                <input type="hidden" name="garageId" value="@Model.Id" />
            
                                    <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm position-relative">

                                    <span class="spinner-border spinner-border-sm spinner-btn me-2" role="status" aria-hidden="true" style="display: none;"></span>
                
                                    <i class="bi bi-p-square-fill me-2"></i>
                                    <span class="btn-text">Park My Car Here</span>
                                    </button>
                                </form>
                            }
                        else
                            {
                                <button class="btn btn-outline-secondary btn-lg px-5" disabled>
                                <i class="bi bi-exclamation-octagon me-2"></i> Garage Full
                                </button>
                            }
                        }
                </div>

                <div class="mt-4 p-3 rounded"
                     style="background-color: var(--bg-main); border: 1px solid var(--border);">
                    <label class="text-muted small text-uppercase fw-bold d-block">
                        Parking Fees
                    </label>

                    <ul class="list-unstyled mb-0">
                        <li>Hourly: <strong>@Model.HourlyRate.ToString("C", new CultureInfo("fr-FR"))</strong></li>
                        <li>Daily: <strong>@Model.DailyRate.ToString("C", new CultureInfo("fr-FR"))</strong></li>
                        <li>Monthly: <strong>@Model.MonthlyRate.ToString("C", new CultureInfo("fr-FR"))</strong></li>
                    </ul>
                </div>

                @if (Model.CanSeeRevenue)
                {
                    <div class="mt-4 p-3 rounded"
                         style="background-color: var(--bg-main); border: 1px solid var(--border);">
                        <label class="text-muted small text-uppercase fw-bold d-block">
                            Total Revenue
                        </label>
                        <span class="fs-4 text-success fw-bold">
                            @Model.TotalRevenue.ToString("C", new CultureInfo("fr-FR"))
                        </span>
                    </div>
                }

            </div>
        </div>

        <div class="card-footer py-3">
            <div class="d-flex justify-content-between align-items-center">
                <a asp-action="Index" class="btn btn-info btn-sm">
                    <i class="bi bi-arrow-left me-1"></i> Back to Garage Map
                </a>

                @if (User.IsInRole("GarageOwner"))
                {
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="btn btn-danger btn-sm"
                                onclick="return confirm('Are you sure you want to remove @Model.Name?')">
                            Delete Garage
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
}