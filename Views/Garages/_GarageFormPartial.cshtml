@model CarsInsideGarage.Models.ViewModels.GarageCreateViewModel

<div class="card shadow p-4">

    <div class="card-header">
        <h3 class="mb-0">New Garage Entry</h3>
    </div>

    <h3 class="text-white mb-4">Create New Garage</h3>
    <form asp-action="Create" class="needs-spinner">
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label">Garage Name</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3 text-start">
            <label asp-for="Capacity" class="form-label text-muted small fw-bold">Capacity</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-accent">#</span>
                <input asp-for="Capacity"
                       type="number"
                       step="1"
                       min="1"
                       class="form-control"
                       onfocus="this.select();" />
            </div>
            <span asp-validation-for="Capacity" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SelectedArea" class="form-label">City Area</label>
            <select asp-for="SelectedArea" asp-items="Html.GetEnumSelectList<CarsInsideGarage.Data.Enums.Area>()" class="form-select">
                <option value="">-- Choose Area --</option>
            </select>
            <span asp-validation-for="SelectedArea" class="text-danger"></span>
        </div>

            <div class="col-md-4 mb-3">
            <label asp-for="Lat" class="form-label text-muted small fw-bold text-uppercase">Latitude</label>
                <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-accent">#</span>
               
                <input asp-for="Lat" step="any" class="form-control" type="number" placeholder="e.g. 42.6977" onfocus="this.select();" />
                </div>
            <span asp-validation-for="Lat" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
            <label asp-for="Lng" class="form-label text-muted small fw-bold text-uppercase">Longitude</label>
                <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-accent">#</span>
               
                <input asp-for="Lng" step="any" class="form-control" type="number" placeholder="e.g. 23.3219" onfocus="this.select();" />
                </div>
            <span asp-validation-for="Lng" class="text-danger"></span>
            </div>

        <div class="mb-3 text-start">
            <label asp-for="HourlyRate" class="form-label text-muted small fw-bold">HourlyRate</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-accent">€</span>
                <input asp-for="HourlyRate"
                       type="number"
                       step="1"
                       min="1"
                       class="form-control"
                       onfocus="this.select();" />
            </div>
            <span asp-validation-for="HourlyRate" class="text-danger"></span>
        </div>

        <div class="mb-3 text-start">
            <label asp-for="DailyRate" class="form-label text-muted small fw-bold">DailyRate</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-accent">€</span>
                <input asp-for="DailyRate"
                       type="number"
                       step="1"
                       min="1"
                       class="form-control"
                       onfocus="this.select();" />
            </div>
            <span asp-validation-for="DailyRate" class="text-danger"></span>
        </div>

        <div class="mb-3 text-start">
            <label asp-for="MonthlyRate" class="form-label text-muted small fw-bold">MonthlyRate</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-accent">€</span>
                <input asp-for="MonthlyRate"
                       type="number"
                       step="1"
                       min="1"
                       class="form-control"
                       onfocus="this.select();" />
            </div>
            <span asp-validation-for="MonthlyRate" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-register w-100 mt-3">
            <span class="spinner-border spinner-btn" role="status"></span>
            Register Garage
        </button>
    </form>
</div>