@model CarsInsideGarage.Models.ViewModels.PricingUpdateViewModel

@{
    ViewData["Title"] = "Update Pricing";
    }

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-lg border-0">
                    <div class="card-header bg-surface py-3">
                        <h4 class="mb-0 text-accent">
                        <i class="bi bi-currency-euro me-2"></i>Update Garage Pricing
                        </h4>
                    </div>
                
                    <div class="card-body p-4">
                        <form asp-action="UpdatePricing" method="post">
                        <input type="hidden" asp-for="GarageId" />

                            <div class="row mb-4">
                            <!-- Hourly Rate -->
                                <div class="col-md-4 mb-3">
                                <label asp-for="HourlyRate" class="form-label text-muted small fw-bold text-uppercase">Hourly Rate</label>
                                    <div class="input-group">
                                    <span class="input-group-text bg-main border-border text-accent">€</span>
                                    <input asp-for="HourlyRate" class="form-control" type="number" step="0.01" />
                                    </div>
                                <span asp-validation-for="HourlyRate" class="text-danger"></span>
                                </div>

                            <!-- Daily Rate -->
                                <div class="col-md-4 mb-3">
                                <label asp-for="DailyRate" class="form-label text-muted small fw-bold text-uppercase">Daily Rate</label>
                                    <div class="input-group">
                                    <span class="input-group-text bg-main border-border text-accent">€</span>
                                    <input asp-for="DailyRate" class="form-control" type="number" step="0.01" />
                                    </div>
                                <span asp-validation-for="DailyRate" class="text-danger"></span>
                                </div>

                            <!-- Monthly Rate -->
                                <div class="col-md-4 mb-3">
                                <label asp-for="MonthlyRate" class="form-label text-muted small fw-bold text-uppercase">Monthly Rate</label>
                                    <div class="input-group">
                                    <span class="input-group-text bg-main border-border text-accent">€</span>
                                    <input asp-for="MonthlyRate" class="form-control" type="number" step="0.01" />
                                    </div>
                                <span asp-validation-for="MonthlyRate" class="text-danger"></span>
                                </div>
                            </div>

                        <hr class="border-border my-4" />

                        <h5 class="text-white mb-3">Pricing Rules</h5>
                            <div id="rules-container" class="bg-main p-3 rounded border border-dashed mb-4">
                                <p class="text-muted small mb-0 italic">
                                <i class="bi bi-info-circle me-1"></i> Special pricing rules (e.g. Weekend rates) can be managed here.
                                </p>
                            <!-- Optional: dynamic rules later -->
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <a href="javascript:history.back()" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Cancel
                                </a>
                                <button type="submit" class="btn btn-primary px-5">
                                <i class="bi bi-save me-2"></i> Save Changes
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>