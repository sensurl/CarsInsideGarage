@model CarsInsideGarage.Models.ViewModels.SelectCarViewModel

@{
    ViewData["Title"] = "Select Vehicle";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="display-6 fw-bold text-white">
            <i class="bi bi-car-front-fill text-accent me-2"></i>Select Your Vehicle
        </h2>
        <p class="text-muted">
            You are entering: <span class="text-accent fw-bold">@Model.GarageName</span>
        </p>
        <hr class="w-25 mx-auto border-secondary" />
    </div>

    <div class="row justify-content-center g-4">
        @foreach (var car in Model.AvailableCars)
        {
            <div class="col-md-4">
                <form asp-action="Start" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="garageId" value="@Model.GarageId" />
                    <input type="hidden" name="carId" value="@car.Id" />

                    <button type="submit" class="card h-100 w-100 text-start border-0 shadow-sm bg-surface p-0 car-selection-card"
                            style="transition: transform 0.2s, border-color 0.2s; cursor: pointer; background: none; display: block;">
                        
                        <div class="card-body p-4 border rounded" style="border: 1px solid var(--border) !important;">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="icon-box rounded-circle bg-main p-3" style="background-color: var(--bg-main) !important;">
                                    <i class="bi bi-car-front text-accent fs-3"></i>
                                </div>
                                <span class="badge rounded-pill" style="background-color: var(--bg-main); color: var(--accent); border: 1px solid var(--border);">
                                    Available
                                </span>
                            </div>

                            <h5 class="text-white mb-1">Vehicle Registration</h5>
                            <h3 class="font-monospace text-accent mb-0">@car.CarPlateNumber</h3>
                            
                            <div class="mt-4 d-flex align-items-center text-muted small">
                                <i class="bi bi-arrow-right-circle me-2"></i>
                                <span>Click to park this car</span>
                            </div>
                        </div>
                    </button>
                </form>
            </div>
        }

        <div class="col-md-4">
            <a asp-controller="Cars" asp-action="Create" class="text-decoration-none h-100">
                <div class="card h-100 border-dashed bg-transparent d-flex align-items-center justify-content-center p-4"
                     style="border: 2px dashed var(--border); min-height: 200px; transition: all 0.3s;">
                    <div class="text-center text-muted">
                        <i class="bi bi-plus-circle display-5 mb-2"></i>
                        <p class="mb-0 fw-bold">Register Another Car</p>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <div class="text-center mt-5">
        <a asp-controller="Garages" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-chevron-left"></i> Back to Garages
        </a>
    </div>
</div>

