<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - YourParkingSpot</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CarsInsideGarage.styles.css" asp-append-version="true" />
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-p-circle-fill text-accent"></i> YourParkingSpot
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link nav-btn me-2" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-btn me-2" asp-area="" asp-controller="Garages" asp-action="Index">Find Parking</a>
                        </li>

                        @if (User.IsInRole("Driver") || User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown me-2">
                                <a class="nav-link dropdown-toggle nav-btn" href="#" id="driverDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-car-front-fill me-1"></i> Driver Panel
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Cars" asp-action="Index">My Vehicles (Registry)</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="ParkingSessions" asp-action="MySessions">Active Sessions</a></li>
                                </ul>
                            </li>
                        }

                        @if (User.IsInRole("Driver") && !User.IsInRole("Admin"))
                        {

                            <div class="driver-steps d-none d-lg-flex">
                                @{
                                    var step = TempData["Step"] != null ? (int)TempData["Step"] : -1;
                                    TempData.Keep("Step"); 
                                }

                                <span class="step @(step >= 0 ? "done" : "")" data-title="Register Car">0</span>
                                <span class="step @(step >= 1 ? "done" : "")" data-title="Location">1</span>
                                <span class="step @(step >= 2 ? "done" : "")" data-title="Select Garage">2</span>
                                <span class="step @(step >= 3 ? "done" : "")" data-title="Park">3</span>
                                <span class="step @(step >= 4 ? "done" : "")" data-title="Pay & Exit">4</span>
                            </div>
                        }

                        @if (User.IsInRole("GarageOwner") || User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown me-2">
                                <a class="nav-link dropdown-toggle nav-btn" href="#" id="ownerDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-workspace me-1"></i> Owner Panel
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item text-accent" asp-area="" asp-controller="Garages" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>Register New Garage</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Garages" asp-action="Index">My Garages</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="ParkingSessions" asp-action="ActiveList">Current Occupancy</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Fees" asp-action="Index">Manage Fees</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Garages" asp-action="RevenueReport">Revenue & Accounting</a></li>
                                </ul>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item border-start ms-2 ps-2">
                                <a class="nav-link nav-btn border-info text-info" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-shield-lock-fill me-1"></i> Admin Dashboard
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="text-muted small me-3">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </span>
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    <button type="submit" class="btn btn-info px-4 py-2" style="color: var(--text-muted) !important; border-color: var(--border) !important;">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-accent fw-bold me-2" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm" asp-area="" asp-controller="Account" asp-action="Register">Join Now</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - YourUltimateParkingAssistant - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>