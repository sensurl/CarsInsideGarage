@model int

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 bg-surface text-center p-5" style="border: 1px solid var(--border) !important;">
                <div class="mb-4">
                    <i class="bi bi-check-circle-fill display-1 text-accent"></i>
                </div>
                
                <h2 class="text-white fw-bold mb-3">Payment Successful</h2>
                
                <p class="text-muted fs-5 mb-4">
                    Your payment for session <span class="text-accent fw-bold">#@Model</span>
                    has been processed and cleared.
                </p>

                <div class="d-grid gap-2">
                    <a asp-action="MySessions" class="btn btn-register py-3">
                        <i class="bi bi-arrow-left me-2"></i> Back to My Sessions
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>