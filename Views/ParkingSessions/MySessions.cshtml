@model IEnumerable<CarsInsideGarage.Models.ViewModels.SessionActiveViewModel>

@{
    ViewData["Title"] = "My Active Sessions";
 }

<h2 class="mb-4">My Active Parking Sessions</h2>

@if (!Model.Any())
{
    <p class="text-muted">No active sessions.</p>
}
else
{
    @foreach (var session in Model)
    {
        <div class="card bg-surface border-0 mb-3 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="text-accent mb-0">@session.CarPlateNumber</h5>
                    <small class="text-muted">@session.GarageName • Parked @session.EntryTime.ToString("HH:mm")</small>
                </div>
                <div class="text-end">
                    <div class="fw-bold text-white">@session.AccruedAmount.ToString("C")</div>
                    @if (session.RemainingAmount > 0)
                    {
                        <span class="badge bg-danger-subtle text-danger">Due: @session.RemainingAmount.ToString("C")</span>
                    }
                    else
                    {
                        <span class="badge bg-success-subtle text-success">Ready to Exit</span>
                    }
                </div>
                <div class="ms-4">
                    <a asp-action="Active" asp-route-id="@session.Id" class="btn btn-outline-accent btn-sm">
                        Details & Payment <i class="bi bi-gear-fill ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    }
}
